generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum ExpenseCategory {
  FREIGHT
  PORTER
  FOOD
  OFFICE_GOODS
  HOTEL
  PETROL
  DIESEL
  OTHER
  TRAVEL
  TRANSPORTATION
  ACCOMMODATION
  OFFICE_SUPPLIES
  COMMUNICATION
  ENTERTAINMENT
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  password     String
  role         Role      @default(MEMBER)
  totalBudget  Float     @default(5000)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  expenses     Expense[]
  funds        Fund[]
}

model Expense {
  id           String   @id @default(cuid())
  title        String
  description  String?
  amount       Float
  editCount    Int      @default(0)
  category     ExpenseCategory
  status       ExpenseStatus   @default(PENDING)
  adminRemark  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

enum PaymentMode {
  CASH
  GPAY
  BANK_ACCOUNT
}

model Fund {
  id            String      @id @default(cuid())
  amount        Float
  receivedFrom  String
  paymentMode   PaymentMode
  upiId         String?
  accountNumber String?
  fundDate      DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}
